<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Création de la vue liste Notaire -->
    <record id="cdns_notaire_view_list" model="ir.ui.view">
        <field name="name">cdns.notaire.view.list</field>
        <field name="model">cdns.notaire</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="prenom" />
                <field name="nom_famille" />
                <field name="numero_agrement" />
                <field name="date_nomination" />
            </list>
        </field>
    </record>
    
    <!-- Création de la vue form Notaire -->
    <record id="cdns_notaire_view_form" model="ir.ui.view">
        <field name="name">cdns.notaire.view.form</field>
        <field name="model">cdns.notaire</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="prenom" />
                            <field name="nom_famille" /> 
                            <field name="sexe" />
                            <field name="nombre_dossier" />
                        </group>
                         <group>
                            <field name="numero_agrement" />
                            <field name="date_nomination" />
                            <field name="numero_telephone" />
                            <field name="adresse_email" />
                        </group>
                    </group>
                    <notebook>
                        <page name="liste_dossier_notaire" string="Liste des dossiers">
                            <field name="dossier_ids" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action du menu Notaire -->
    <record model="ir.actions.act_window" id="action_menu_notaire">
        <field name="name">Notaires</field>
        <field name="res_model">cdns.notaire</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="cdns_notaire_view_list"/>
    </record>

</odoo>
