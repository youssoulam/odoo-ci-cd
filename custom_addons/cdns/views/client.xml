<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue form client -->
    <record id="cdns_client_view_form" model="ir.ui.view">
        <field name="name">cdns.client.view.form</field>
        <field name="model">cdns.client</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <!-- Smart button documents -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_documents"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file">
                            <field name="piece_count" widget="statinfo" string="Documents"/>
                        </button>
                    </div>

                    <!-- Photo / Logo -->
                    <field name="image_1920"
                           widget="image"
                           class="oe_avatar"
                           options="{'preview_image': 'image_128'}"/>

                    <!-- Type + Nom -->
                    <div class="oe_title">
                        <field name="type_client"
                               widget="radio"
                               options="{'horizontal': true}"/>
                        <h1>
                            <field name="name"
                                   placeholder="Nom ou Dénomination sociale..."/>
                        </h1>
                    </div>

                    <!-- ========== PERSONNE PHYSIQUE ========== -->
                    <group string="Informations personnelles"
                           invisible="type_client != 'personne'">
                        <group>
                            <field name="date_naissance"/>
                            <field name="lieu_naissance"/>
                            <field name="nationalite"/>
                            <field name="numero_identite"/>
                        </group>
                        <group>
                            <field name="telephone_mobile"/>
                            <field name="situation_matrimoniale"/>
                        </group>
                    </group>

                    <!-- ========== ENTREPRISE ========== -->
                    <group string="Informations société"
                           invisible="type_client != 'entreprise'">
                        <group>
                            <field name="forme_juridique"/>
                            <field name="rccm"/>
                            <field name="ninea"/>
                        </group>
                        <group>
                            <field name="telephone_mobile"/>
                        </group>
                    </group>

                    <!-- ========== DOMICILE (personne) ========== -->
                    <group string="Domicile"
                           invisible="type_client != 'personne'">
                        <field name="street" placeholder="Rue..."/>
                        <field name="street2" placeholder="Complément d'adresse..."/>
                        <div class="o_address_format" colspan="2">
                            <field name="zip"
                                   class="o_address_zip"
                                   placeholder="Code Postal"/>
                            <field name="city"
                                   class="o_address_city"
                                   placeholder="Ville"/>
                            <field name="state_id"
                                   class="o_address_state"
                                   placeholder="Province/État"
                                   options="{'no_open': True}"
                                   domain="[('country_id', '=', country_id)]"/>
                        </div>
                        <field name="country_id"
                               placeholder="Pays"
                               options="{'no_open': True}"/>
                    </group>

                    <!-- ========== SIÈGE SOCIAL (entreprise) ========== -->
                    <group string="Siège social"
                           invisible="type_client != 'entreprise'">
                        <field name="street" placeholder="Rue..."/>
                        <field name="street2" placeholder="Complément d'adresse..."/>
                        <div class="o_address_format" colspan="2">
                            <field name="zip"
                                   class="o_address_zip"
                                   placeholder="Code Postal"/>
                            <field name="city"
                                   class="o_address_city"
                                   placeholder="Ville"/>
                            <field name="state_id"
                                   class="o_address_state"
                                   placeholder="Province/État"
                                   options="{'no_open': True}"
                                   domain="[('country_id', '=', country_id)]"/>
                        </div>
                        <field name="country_id"
                               placeholder="Pays"
                               options="{'no_open': True}"/>
                    </group>

                    <!-- Onglet pièces jointes -->
                    <notebook>
                        <page string="Pièces jointes">
                            <field name="piece_ids"
                                   context="{'default_res_model': 'cdns.client'}"
                                   widget="attachment"/>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue liste -->
    <record id="cdns_client_view_list" model="ir.ui.view">
        <field name="name">cdns.client.view.list</field>
        <field name="model">cdns.client</field>
        <field name="arch" type="xml">
            <list>
                <field name="image_128" widget="image" optional="show"/>
                <field name="name"/>
                <field name="type_client"/>
                <field name="telephone_mobile"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="piece_count" string="Documents"/>
            </list>
        </field>
    </record>

    <!-- Action menu client -->
    <record model="ir.actions.act_window" id="action_menu_client">
        <field name="name">Clients</field>
        <field name="res_model">cdns.client</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>