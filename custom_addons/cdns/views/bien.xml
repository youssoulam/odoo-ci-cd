<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Création de la vue liste bien immobilier -->
    <record id="cdns_bien_view_list" model="ir.ui.view">
        <field name="name">cdns.bien.view.list</field>
        <field name="model">cdns.bien</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="type_bien" />
                <field name="valeur_estime" />
                <field name="superficie" />
            </list>
        </field>
    </record>
    
    <!-- Création de la vue form bien immobilier -->
    <record id="cdns_bien_view_form" model="ir.ui.view">
        <field name="name">cdns.bien.view.form</field>
        <field name="model">cdns.bien</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="type_bien" />
                        <field name="valeur_estime" />
                        <field name="superficie" />
                    </group>
                    <notebook>
                        <page name="liste_acte_bien" string="Liste des actes">
                            <field name="acte_ids" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action du menu bien immobilier -->
    <record model="ir.actions.act_window" id="action_menu_bien">
        <field name="name">Biens Immobiliers</field>
        <field name="res_model">cdns.bien</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="cdns_bien_view_list"/>
    </record>

</odoo>
