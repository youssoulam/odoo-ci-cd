<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Création de la vue liste spécialité --> 
    <record id="cabinet_avocat_speciality_view_list" model="ir.ui.view">
        <field name="name">cabinet.avocat.speciality.view.list</field>
        <field name="model">cabinet.avocat.speciality</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="nombre_avocat" />
            </list>
        </field>
    </record>
    
    <!-- Création de la vue form spécialité -->
    <record id="cabinet_avocat_speciality_view_form" model="ir.ui.view">
        <field name="name">cabinet.avocat.speciality.view.form</field>
        <field name="model">cabinet.avocat.speciality</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="nombre_avocat" />
                    </group>
                    <notebook>
                        <page name="speciality_avocat" string="Liste des spécialité">
                            <field name="avocat_ids" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action du menu Spécialité  -->
    <record model="ir.actions.act_window" id="action_menu_speciality">
        <field name="name">Spécialité</field>
        <field name="res_model">cabinet.avocat.speciality</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="cabinet_avocat_speciality_view_list"/>
    </record>


</odoo>
