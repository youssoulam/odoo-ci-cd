<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Création de la vue liste affaire -->
    <record id="cabinet_avocat_affaire_view_list" model="ir.ui.view"> 
        <field name="name">cabinet.avocat.affaire.view.list</field>
        <field name="model">cabinet.avocat.affaire</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="titre" />
                <field name="client_id" />
                <field name="type_procedure" />
            </list>
        </field>
    </record>
    
    <!-- Création de la vue form affaire -->
    <record id="cabinet_avocat_affaire_view_form" model="ir.ui.view">
        <field name="name">cabinet.avocat.affaire.view.form</field>
        <field name="model">cabinet.avocat.affaire</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="titre" />    
                            <field name="status" />  
                        </group>
                         <group>
                            <field name="client_id" />
                            <field name="type_procedure" />
                        </group>
                    </group>
                    <notebook>
                        <page name="liste_avocat" string="Avocats Assignés">
                            <field name="avocat_ids" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action du menu Affaire  -->
    <record model="ir.actions.act_window" id="action_menu_affaire">
        <field name="name">Affaire</field>
        <field name="res_model">cabinet.avocat.affaire</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="cabinet_avocat_affaire_view_list"/>
    </record>

</odoo>
