<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Création de la vue liste audience -->
    <record id="cabinet_avocat_audience_view_list" model="ir.ui.view"> 
        <field name="name">cabinet.avocat.audience.view.list</field>
        <field name="model">cabinet.avocat.audience</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="date_audience" />
                <field name="affaire_id" />
            </list>
        </field>
    </record>
    
    <!-- Création de la vue form audience -->
    <record id="cabinet_avocat_audience_view_form" model="ir.ui.view">
        <field name="name">cabinet.avocat.audience.view.form</field>
        <field name="model">cabinet.avocat.audience</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="date_audience" />
                        <field name="affaire_id" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action du menu Audience  -->
    <record model="ir.actions.act_window" id="action_menu_audience">
        <field name="name">Audience</field>
        <field name="res_model">cabinet.avocat.audience</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="cabinet_avocat_audience_view_list"/>
    </record>

</odoo>
