<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Création de la vue liste client -->
    <record id="cabinet_avocat_client_view_list" model="ir.ui.view"> 
        <field name="name">cabinet.avocat.client.view.list</field>
        <field name="model">cabinet.avocat.client</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="type_client" />
                <field name="email" />
                <field name="phone" />
            </list>
        </field>
    </record>
    
    <!-- Création de la vue form client -->
    <record id="cabinet_avocat_client_view_form" model="ir.ui.view">
        <field name="name">cabinet.avocat.client.view.form</field>
        <field name="model">cabinet.avocat.client</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="type_client" />
                            <field name="adress" />
                        </group>
                         <group>
                            <field name="email" />
                            <field name="phone" />
                        </group>
                    </group>
                    <notebook>
                        <page name="affaire_client" string="Affaires Associées">
                            <field name="affaire_ids" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action du menu Client  -->
    <record model="ir.actions.act_window" id="action_menu_client">
        <field name="name">Client</field>
        <field name="res_model">cabinet.avocat.client</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="cabinet_avocat_client_view_list"/>
    </record>

</odoo>
